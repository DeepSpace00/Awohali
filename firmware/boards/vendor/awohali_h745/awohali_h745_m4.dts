/dts-v1/;
#include <st/h7/stm32h745Xi_m4.dtsi>
#include "awohali_h745.dtsi"

/ {
	model = "Awohali STM32H745ZI board";
	compatible = "st,stm32h745xx";

	/* HW resources belonging to CM4 */
	chosen {
		zephyr,sram = &sram1;
		zephyr,flash = &flash1;
	};

	aliases {
		led0 = &led0;
		can0 = &fdcan1;
		eeprom0 = &eeprom_0;
	};

	leds {
		compatible = "gpio-leds";
		status = "okay";
		led0: led_0 {
			gpios = <&gpiob 8 GPIO_ACTIVE_HIGH>;
			label = "LED_BUILTIN";
		};
	};

	gnss-load-switch {
		compatible = "regulator-fixed";
		enable-gpios = <&gpioe 10 GPIO_ACTIVE_HIGH>;
		regulator-name = "gnss-pwr";
		status = "okay";
	};

	lte-load-switch {
		compatible = "regulator-fixed";
		enable-gpios = <&gpioc 13 GPIO_ACTIVE_HIGH>;
		regulator-name = "lte-pwr";
		status = "okay";
	};
};

&fdcan1 {
	pinctrl-0 = <&fdcan1_tx_pd1 &fdcan1_rx_pd0>;
	pinctrl-names = "default";
	clocks = <&rcc STM32_CLOCK(APB1_2, 8)>,
		<&rcc STM32_SRC_HSE FDCAN_SEL(1)>;
	status = "okay";

	can-transceiver {
		max-bitrate = <5000000>;
	};
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb7>;
	pinctrl-names = "default";
	clock-frequency = <100000>;
	status = "okay";

	eeprom0: eeprom@50 {
		compatible = "st,m24xxx", "atmel,at24";
		reg = <0x50>;
		size = <DT_SIZE_K(64)>;
		pagesize = <128>;
		address-width = <16>;
		timeout = <5>;
		status = "okay";
	};

	usb_hub: usb2422@2c {
		compatible = "microchip,usb2422";
		reg = <0x2C>;
		reset-gpios = <&gpiob 1 GPIO_ACTIVE_LOW>;

		max-current-ma = <500>;
		self-powered;
		status = "okay";
	};

	lps28dfw@5c {
		compatible = "st,lps28dfw-i2c";
		reg = <0x5C>;
		status = "okay";
	};

	sht4x@44 {
		compatible = "sensirion,sht4x";
		reg = <0x44>;
		repeatability = <2>;
		status = "okay";
	};
};

&i2c2 {
	pinctrl-0 = <&i2c2_scl_pb10 &i2c2_sda_pb11>;
	pinctrl-names = "default";
	clock-frequency = <100000>;
	status = "okay";
};

&i2c3 {
	pinctrl-0 = <&i2c3_scl_pa8 &i2c3_sda_pc9>;
	pinctrl-names = "default";
	clock-frequency = <100000>;
	status = "okay";
};

&spi1 {
	pinctrl-0 = <&spi1_nss_pa4 &spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pd7>;
	pinctrl-names = "default";
	status = "okay";
};

&usart3 {
	pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&rcc {
	clock-frequency = <DT_FREQ_M(64)>;
};

&gpioc {
	gpio-hog-grant {
		gpio-hog;
		gpios = <2 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "spi-bus-grant";
	};

	gpio-hog-request {
		gpio-hog;
		gpios = <3 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "spi-bus-request";
	};
};

&gpiod {
	gpio-hog-l4-reset {
		gpio-hog;
		gpios = <3 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "l4-reset";
	};

	gpio-hog-l4-boot {
		gpio-hog;
		gpios = <4 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "l4-boot";
	};

	gpio-hog-can-stb {
		gpio-hog;
		gpios = <2 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "can-stb";
	};
};

&gpioa {
	gpio-hog-eth-reset {
		gpio-hog;
		gpios = <3 GPIO_ACTIVE_LOW>;
		output-high;
		line-name = "eth-reset";
	};
};

&gpioc {
	gpio-hog-eeprom-wc {
		gpio-hog;
		gpios = <15 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
		output-high;
		line-name = "eeprom-wc";
	};
};