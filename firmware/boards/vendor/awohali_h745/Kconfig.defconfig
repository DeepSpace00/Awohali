# Awohali_H745 board configuration

# SPDX-License-Identifier: Apache-2.0

if BOARD_AWOHALI_H745

# Mailbox is required for inter-core communication on both cores
config MBOX
    default y

if BOARD_AWOHALI_H745_STM32H745XX_M4

config UART_CONSOLE
	default n

endif # BOARD_AWOHALI_H745_STM32H745XX_M4

endif # BOARD_AWOHALI_H745