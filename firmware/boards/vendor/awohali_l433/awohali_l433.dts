/dts-v1/;
#include <st/l4/stm32l433Xc.dtsi>
#include <st/l4/stm32l433rctxp-pinctrl.dtsi>

/ {
	model = "Awohali_L433 Board";
	compatible = "st,stm32l433xx";

	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &can1;
	};

	aliases {
		led0 = &led0;
		can0 = &can1;
		eeprom0 = &eeprom0;
	};

	leds {
		compatible = "gpio-leds";
		status = "okay";
		led0: led_0 {
			gpios = <&gpioh 1 GPIO_ACTIVE_HIGH>;
			label = "LED_BUILTIN";
		};
	};

	reg-1v8 {
		compatible = "regulator-gpio";
		regulator-name = "+1V8 SMPS";
		enable-gpios = <&gpiob 2 GPIO_ACTIVE_HIGH>;
		gpios = <&gpiob 1 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};

	reg-2v8 {
		compatible = "regulator-gpio";
		regulator-name = "+2V8 LDO";
		enable-gpios = <&gpiob 3 GPIO_ACTIVE_HIGH>;
		gpios = <&gpioa 15 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};
};

&can1 {
	pinctrl-0 = <&can1_tx_pb9 &can1_rx_pb8>;
	pinctrl-names = "default";
	status = "okay";

	can-transceiver {
		max-bitrate = <5000000>;
	};
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pa9 &i2c1_sda_pa10>;
	pinctrl-names = "default";
	clock-frequency = <100000>;
	status = "okay";

	eeprom0: eeprom_0@50 {
		compatible = "atmel,at24";
		reg = <0x50>;
		size = <DT_SIZE_K(65536)>;
		pagesize = <128>;
		address-width = <16>;
		timeout = <5>;
		status = "okay";
	};

	bq25798@6b {
		compatible = "ti,bq25798";
		reg = <0x6B>;
		cell-count = <2>;
		constant-charge-current-max-microamp = <1000000>;
		constant-charge-voltage-max-microvolt = <7300000>;
		int-gpios = <&gpioa 2 GPIO_ACTIVE_LOW>;
		ce-gpios = <&gpiob 15 GPIO_ACTIVE_LOW>;
		qon-gpios = <&gpiob 14 GPIO_ACTIVE_LOW>;
		status = "okay";
	};

	bq76905@10 {
		compatible = "ti,bq76905";
		reg = <0x10>;
		cell-count = <2>;
		alert-gpios = <&gpiob 11 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};
};

&spi1 {
	pinctrl-0 = <&spi1_nss_pa4 &spi1_sck_pa1 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	status = "okay";
};

&usb {
	pinctrl-0 = <&usb_dm_pa11 &usb_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";

	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-usart";
		status = "okay";
	};
};

&clk_hsi {
    status = "okay";
};

&pll {
    div-m = <4>;
    mul-n = <32>;
    div-p = <7>;
    div-q = <2>;
    div-r = <2>;
    clocks = <&clk_hsi>;
    status = "okay";
};

&rcc {
    clocks = <&pll>;
    clock-frequency = <DT_FREQ_M(64)>;
    ahb-prescaler = <1>;
    apb1-prescaler = <1>;
    apb2-prescaler = <1>;
};

&gpioa {
	gpio-hog-can-stb {
		gpio-hog;
		gpios = <0 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "can-stb";
	};

	gpio-hog-eeprom-wc {
		gpio-hog;
		gpios = <3 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
		output-high;
		line-name = "eeprom-wc";
	};

	gpio-hog-h7-boot {
		gpio-hog;
		gpios = <5 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "h7-boot";
	};
};

&gpiob {
	gpio-hog-h7-reset {
		gpio-hog;
		gpios = <4 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "h7-reset";
	};

	gpio-hog-pg-3v3 {
		gpio-hog;
		gpios = <10 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "pg-3v3";
	};

	gpio-hog-grant {
		gpio-hog;
		gpios = <12 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "spi-bus-grant";
	};
	gpio-hog-request {
		gpio-hog;
		gpios = <13 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "spi-bus-request";
	};
};