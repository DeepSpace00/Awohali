# Enable MPU
CONFIG_ARM_MPU=y

# Enable GPIO
CONFIG_GPIO=y

# Enable I2C
CONFIG_I2C=y

# Enable CAN
CONFIG_CAN=y

# Enable SPI
CONFIG_SPI=y

# Enable clock control
CONFIG_CLOCK_CONTROL=y

# Console
CONFIG_CONSOLE=y

# Enable USB
CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_CDC_ACM=y
CONFIG_UART_LINE_CTRL=y
CONFIG_USB_DEVICE_INITIALIZE_AT_BOOT=y
CONFIG_CDC_ACM_DTE_RATE_CALLBACK_SUPPORT=y

# USB enumeration settings
CONFIG_USB_DEVICE_VID=0x1209
CONFIG_USB_DEVICE_PID=0x0001
CONFIG_USB_DEVICE_MANUFACTURER="DeepSpace Engineering"
CONFIG_USB_DEVICE_PRODUCT="Awohali"
CONFIG_USB_DEVICE_SN="0001"