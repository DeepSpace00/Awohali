# Enable MPU
CONFIG_ARM_MPU=y

# Enable GPIO
CONFIG_GPIO=y

# Enable UART
CONFIG_SERIAL=y

# Enable I2C
CONFIG_I2C=y

# Enable CAN
CONFIG_CAN=y

# Enable SPI
CONFIG_SPI=y

# Enable clock control
CONFIG_CLOCK_CONTROL=y

# Console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable USB
CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_DEVICE_INITIALIZE_AT_BOOT=y
CONFIG_CDC_ACM_DTE_RATE_CALLBACK_SUPPORT=y